<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0FFFFFFF" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#38FFFFFF" />
        </shape>
    </item>
    <item android:top="2dp" android:left="4dp" android:right="4dp" android:bottom="44dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#75FFFFFF"
                android:endColor="#00000000" />
            <corners
                android:topLeftRadius="18dp"
                android:topRightRadius="18dp"
                android:bottomLeftRadius="6dp"
                android:bottomRightRadius="6dp" />
        </shape>
    </item>
    <item android:top="44dp" android:left="4dp" android:right="4dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#00000000"
                android:endColor="#1ED7F2EE" />
            <corners
                android:topLeftRadius="6dp"
                android:topRightRadius="6dp"
                android:bottomLeftRadius="18dp"
                android:bottomRightRadius="18dp" />
        </shape>
    </item>
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#08FFFFFF"
                android:endColor="#00000000" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</layer-list>
