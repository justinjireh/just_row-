<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0FFFFFFF" />
            <corners android:radius="100dp" />
            <stroke
                android:width="1dp"
                android:color="#44FFFFFF" />
        </shape>
    </item>
    <item android:top="2dp" android:left="3dp" android:right="3dp" android:bottom="22dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#72FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners
                android:topLeftRadius="98dp"
                android:topRightRadius="98dp"
                android:bottomLeftRadius="10dp"
                android:bottomRightRadius="10dp" />
        </shape>
    </item>
    <item android:top="22dp" android:left="3dp" android:right="3dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#00000000"
                android:endColor="#18D7F2EE" />
            <corners
                android:topLeftRadius="10dp"
                android:topRightRadius="10dp"
                android:bottomLeftRadius="98dp"
                android:bottomRightRadius="98dp" />
        </shape>
    </item>
</layer-list>
