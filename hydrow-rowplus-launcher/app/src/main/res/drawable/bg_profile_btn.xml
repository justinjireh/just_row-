<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/rowplus_amber_12" />
            <corners android:radius="@dimen/card_radius_sm" />
            <stroke
                android:width="1dp"
                android:color="@color/rowplus_amber_30" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/rowplus_surface_hover" />
            <corners android:radius="@dimen/card_radius_sm" />
            <stroke
                android:width="1dp"
                android:color="@color/rowplus_border_hover" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="@dimen/card_radius_sm" />
            <stroke
                android:width="1dp"
                android:color="@color/rowplus_border" />
        </shape>
    </item>
</selector>
