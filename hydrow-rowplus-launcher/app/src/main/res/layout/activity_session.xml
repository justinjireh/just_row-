<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rowplus_bg_deep">

    <!-- Main session content -->
    <LinearLayout
        android:id="@+id/sessionRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ===== HEADER BAR ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingTop="14dp"
            android:paddingEnd="24dp"
            android:paddingBottom="6dp">

            <View
                android:id="@+id/liveIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_live_dot" />

            <TextView
                android:id="@+id/sessionModeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.15"
                android:textColor="@color/rowplus_text_muted"
                android:textSize="12sp"
                tools:text="FREE ROW · LIVE" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/sessionProfileLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/rowplus_text_muted"
                android:textSize="12sp"
                tools:text="Alex" />

            <!-- Expand media to full screen (hidden unless in multi-window) -->
            <ImageView
                android:id="@+id/expandMediaBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_expand_btn"
                android:clickable="true"
                android:contentDescription="@string/expand_media_full"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_expand_full"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Finish & Save button -->
            <LinearLayout
                android:id="@+id/stopButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stop_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingTop="10dp"
                android:paddingEnd="20dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.1"
                    android:text="FINISH &amp; SAVE"
                    android:textColor="@color/rowplus_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== METRICS AREA (fills space above dock) ===== -->
        <FrameLayout
            android:id="@+id/metricsContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Centered metrics cluster -->
            <LinearLayout
                android:id="@+id/metricsCenter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp">

                <!-- Hero distance -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.2"
                    android:text="DISTANCE"
                    android:textColor="@color/rowplus_text_muted"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/metricDistanceHero"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="-0.04"
                    android:lineSpacingMultiplier="0.85"
                    android:textColor="@color/rowplus_text_primary"
                    android:textSize="72sp"
                    tools:text="2,450" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-4dp"
                    android:fontFamily="sans-serif"
                    android:text="meters"
                    android:textColor="@color/rowplus_text_muted"
                    android:textSize="14sp" />

                <!-- Primary metrics: Split, SPM, Watts, Time -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <!-- SPLIT /500M -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_stat_tile"
                        android:minWidth="120dp"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.15"
                            android:text="SPLIT /500M"
                            android:textColor="@color/rowplus_text_muted"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/metricSplit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/rowplus_text_primary"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            tools:text="2:27" />
                    </LinearLayout>

                    <!-- STROKE RATE -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_stat_tile"
                        android:minWidth="100dp"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.15"
                            android:text="SPM"
                            android:textColor="@color/rowplus_text_muted"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/metricSpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/rowplus_text_primary"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            tools:text="26" />
                    </LinearLayout>

                    <!-- WATTS -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_stat_tile"
                        android:minWidth="100dp"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.15"
                            android:text="WATTS"
                            android:textColor="@color/rowplus_text_muted"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/metricWatts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/rowplus_text_primary"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            tools:text="142" />
                    </LinearLayout>

                    <!-- TIME -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_stat_tile"
                        android:minWidth="120dp"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.15"
                            android:text="TIME"
                            android:textColor="@color/rowplus_text_muted"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/metricDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/rowplus_text_primary"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            tools:text="12:34" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Secondary metrics + split chart -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- CAL -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.15"
                            android:text="CAL"
                            android:textColor="@color/rowplus_text_faint"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/metricCalories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/rowplus_text_secondary"
                            android:textSize="20sp"
                            tools:text="186" />
                    </LinearLayout>

                    <!-- STROKES -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.15"
                            android:text="STROKES"
                            android:textColor="@color/rowplus_text_faint"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/metricStrokes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/rowplus_text_secondary"
                            android:textSize="20sp"
                            tools:text="312" />
                    </LinearLayout>

                    <!-- Split chart -->
                    <LinearLayout
                        android:id="@+id/splitChartContainer"
                        android:layout_width="200dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_stat_tile"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.15"
                            android:text="SPLIT CHART"
                            android:textColor="@color/rowplus_text_faint"
                            android:textSize="8sp" />

                        <LinearLayout
                            android:id="@+id/splitChartBars"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_marginTop="4dp"
                            android:layout_weight="1"
                            android:gravity="bottom"
                            android:orientation="horizontal" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Target progress (hidden by default) -->
                <FrameLayout
                    android:id="@+id/targetProgressContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/bg_progress_track" />

                    <View
                        android:id="@+id/targetProgressFill"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/bg_progress_fill" />

                    <TextView
                        android:id="@+id/targetProgressLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|top"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/rowplus_teal"
                        android:textSize="11sp"
                        tools:text="62% complete" />
                </FrameLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- ===== BOTTOM DOCK BAR ===== -->
        <LinearLayout
            android:id="@+id/dockContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dock_glass"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="10dp"
            android:paddingEnd="20dp"
            android:paddingBottom="14dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/dockRecyclerView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:overScrollMode="never" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom progress bar (hidden) -->
    <FrameLayout
        android:id="@+id/bottomProgressBar"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="bottom"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/rowplus_surface_solid" />

        <View
            android:id="@+id/bottomProgressFill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@color/rowplus_amber" />
    </FrameLayout>
</FrameLayout>
