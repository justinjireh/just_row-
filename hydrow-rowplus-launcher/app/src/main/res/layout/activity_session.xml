<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rowplus_background"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/session_title"
        android:textColor="@color/rowplus_on_background"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/session_profile_label"
        android:textColor="@color/rowplus_muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/sessionProfileValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/rowplus_on_background"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/metricState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@color/rowplus_surface"
        android:padding="16dp"
        android:textColor="@color/rowplus_muted"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/metric_duration_label"
        android:textColor="@color/rowplus_muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/metricDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/metric_duration_default"
        android:textColor="@color/rowplus_on_background"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/metric_distance_label"
        android:textColor="@color/rowplus_muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/metricDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/metric_distance_default"
        android:textColor="@color/rowplus_on_background"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/metric_split_label"
        android:textColor="@color/rowplus_muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/metricSplit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/metric_split_default"
        android:textColor="@color/rowplus_on_background"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/metric_spm_label"
        android:textColor="@color/rowplus_muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/metricSpm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/metric_spm_default"
        android:textColor="@color/rowplus_on_background"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/startStopButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:backgroundTint="@color/rowplus_action"
        android:text="@string/start_mock_session"
        android:textAllCaps="false"
        android:textColor="@color/rowplus_action_text" />

    <Button
        android:id="@+id/finishButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/cancel"
        android:textAllCaps="false" />

</LinearLayout>

