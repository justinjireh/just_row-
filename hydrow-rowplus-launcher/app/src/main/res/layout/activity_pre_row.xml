<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/session_backdrop_nautical" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_session_glass_veil" />

    <TextView
        android:id="@+id/countdownNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_liquid_glass_panel"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="-0.04"
        android:minWidth="220dp"
        android:gravity="center"
        android:paddingStart="36dp"
        android:paddingTop="24dp"
        android:paddingEnd="36dp"
        android:paddingBottom="24dp"
        android:textColor="@color/rowplus_text_primary"
        android:textSize="120sp"
        android:visibility="gone"
        tools:text="3"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/countdownGo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_liquid_glass_panel"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.08"
        android:gravity="center"
        android:minWidth="260dp"
        android:paddingStart="40dp"
        android:paddingTop="26dp"
        android:paddingEnd="40dp"
        android:paddingBottom="26dp"
        android:text="GO"
        android:textColor="@color/rowplus_text_primary"
        android:textSize="118sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <View
        android:id="@+id/countdownRing"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_countdown_ring"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/setupContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_liquid_glass_panel"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="36dp"
            android:paddingTop="30dp"
            android:paddingEnd="36dp"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.2"
                android:text="ROWING AS"
                android:textColor="@color/rowplus_text_muted"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/preRowProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:textColor="@color/rowplus_text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                tools:text="Alex" />

            <View
                android:layout_width="60dp"
                android:layout_height="1dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="28dp"
                android:background="@color/rowplus_divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.2"
                android:text="SESSION TYPE"
                android:textColor="@color/rowplus_text_muted"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/modeFreeRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_mode_pill_selected"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="24dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="12dp"
                    android:text="Free Row"
                    android:textColor="@color/rowplus_text_primary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/modeTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_liquid_glass_button"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="24dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="12dp"
                    android:text="Time Target"
                    android:textColor="@color/rowplus_text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/modeDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_liquid_glass_button"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="24dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="12dp"
                    android:text="Distance Target"
                    android:textColor="@color/rowplus_text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/targetValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif"
                android:textColor="@color/rowplus_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="5,000 m target"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/goButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_liquid_glass_button"
                android:clickable="true"
                android:elevation="8dp"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="34dp"
                android:paddingTop="20dp"
                android:paddingEnd="34dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.15"
                    android:text="BEGIN"
                    android:textColor="@color/rowplus_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/cancelButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_liquid_glass_button"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="22dp"
                android:paddingTop="10dp"
                android:paddingEnd="22dp"
                android:paddingBottom="10dp"
                android:text="Cancel"
                android:textColor="@color/rowplus_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
