<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:id="@+id/profileDialogCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="@drawable/bg_glass_card"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/profileDialogEyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:text="@string/profile_dialog_setup_label"
            android:textColor="@color/rowplus_teal"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/profileDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/rowplus_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/profile_dialog_hint"
            android:textColor="@color/rowplus_text_secondary"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@color/rowplus_divider" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profile_name_label"
            android:textColor="@color/rowplus_text_muted"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/profileNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_profile_input"
            android:fontFamily="sans-serif"
            android:hint="@string/profile_name_hint"
            android:imeOptions="actionNext"
            android:inputType="textCapWords"
            android:maxLines="1"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp"
            android:textColor="@color/rowplus_text_primary"
            android:textColorHint="@color/rowplus_text_muted" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/profile_height_label"
            android:textColor="@color/rowplus_text_muted"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_profile_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="4dp"
            android:paddingEnd="16dp"
            android:paddingBottom="4dp">

            <EditText
                android:id="@+id/profileHeightInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:ems="2"
                android:hint="@string/profile_height_hint"
                android:imeOptions="actionNext"
                android:inputType="number"
                android:maxLines="1"
                android:textColor="@color/rowplus_text_primary"
                android:textColorHint="@color/rowplus_text_muted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_height_suffix"
                android:textColor="@color/rowplus_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/profileHeightPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/profile_height_preview_default"
            android:textColor="@color/rowplus_text_muted"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/profile_weight_label"
            android:textColor="@color/rowplus_text_muted"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_profile_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="4dp"
            android:paddingEnd="16dp"
            android:paddingBottom="4dp">

            <EditText
                android:id="@+id/profileWeightInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:ems="3"
                android:hint="@string/profile_weight_hint"
                android:imeOptions="actionDone"
                android:inputType="number"
                android:maxLines="1"
                android:textColor="@color/rowplus_text_primary"
                android:textColorHint="@color/rowplus_text_muted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_weight_suffix"
                android:textColor="@color/rowplus_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/profileWeightPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/profile_weight_preview_default"
            android:textColor="@color/rowplus_text_muted"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/profileDialogCancelButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_secondary_button"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="18dp"
                android:paddingTop="12dp"
                android:paddingEnd="18dp"
                android:paddingBottom="12dp"
                android:text="@string/cancel"
                android:textColor="@color/rowplus_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/profileDialogSaveButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_start_row"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif"
                android:paddingStart="22dp"
                android:paddingTop="12dp"
                android:paddingEnd="22dp"
                android:paddingBottom="12dp"
                android:text="@string/profile_dialog_save"
                android:textColor="@color/rowplus_on_amber"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
